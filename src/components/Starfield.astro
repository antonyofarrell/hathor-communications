---
interface Props {
  count?: number;
}
const { count = 60 } = Astro.props;

// Positions generated once at build time — no client JS needed.
const stars = Array.from({ length: count }, () => ({
  x: Math.random() * 100,
  y: Math.random() * 100,
  size: Math.random() * 2 + 1,        // 1–3px
  delay: Math.random() * 4,           // staggered so they twinkle out of sync
  duration: Math.random() * 2 + 2,    // 2–4s each
}));
---

<div class="starfield" data-scroll-parallax="20" aria-hidden="true">
  {stars.map((s) => (
    <span
      class="star"
      style={`left:${s.x}%; top:${s.y}%; width:${s.size}px; height:${s.size}px; animation-delay:${s.delay}s; animation-duration:${s.duration}s;`}
    />
  ))}
</div>

<style>
.starfield {
  position: absolute;
  top: -15%;
  left: 0;
  width: 100%;
  height: 130%;      /* taller than its box, so vertical drift hides the seams */
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
  .star {
    position: absolute;
    background: #fff;
    border-radius: 50%;
    opacity: 0.2;
    animation-name: twinkle;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: opacity, transform;
    box-shadow: 0 0 6px 2px #fff;
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.15; transform: scale(0.8); }
    50%      { opacity: 1;    transform: scale(1.3); }
  }
  @media (prefers-reduced-motion: reduce) {
    .star { animation: none; opacity: 0.5; }   /* static dots, no twinkle */
  }
</style>