---
interface Props {
  image: string;
  imageAlt: string;
  heading: string;
  body: string;
  dark?: boolean;
  reverse?: boolean;
  fullWidth?: boolean;
}
const { image, imageAlt, heading, body, dark, reverse, fullWidth } =
  Astro.props;
---

<section
  class="feature"
  class:list={{
    "feature--dark": dark,
    "full-bleed": fullWidth,
  }}
>
  <div class="feature__inner" class:list={{ "feature__inner--reverse": reverse }}>
    <div class="feature__media">
      <img src={image} alt={imageAlt} loading="lazy" data-scroll-parallax="15" />
    </div>
    <div class="feature__text">
      <h2>{heading}</h2>
      <p>{body}</p>
    </div>
  </div>
</section>

<style>
  .feature--dark {
    background: var(--color-footer);
    color: var(--color-footer-copy);
    padding: calc(var(--space) * 2);
    border-radius: var(--image-border);
  }
  .feature__inner {
    display: grid;
    grid-template-columns: 5fr 2fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    max-width: var(--measure);
    margin-inline: auto;
  }
  .feature__inner--reverse {
    grid-template-columns: 2fr 5fr;
  }
  .feature__inner--reverse .feature__media {
    order: 2;
  }
  .feature__inner--reverse .feature__text {
    order: 1;
  }

  .feature__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 8px;
  }
  .feature__media img {
    position: absolute;
    top: -15%;
    left: 0;
    width: 100%;
    height: 130%; /* taller than its frame, so scroll drift hides the seams */
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .feature {
      grid-template-columns: 1fr;
    }
  }
</style>
